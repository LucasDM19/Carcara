{
  "name": "carcara-bot",
  "version": "1.0.0",
  "description": "Carcar\u00e1 \u2014 Bot de apostas automatizado na Polymarket (BTC 5min)",
  "main": "src/index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/index.js --mode=select",
    "market": "node src/index.js --mode=market",
    "select": "node src/index.js --mode=select",
    "watch": "node src/index.js --mode=watch",
    "dry": "node src/index.js --mode=dry",
    "order": "node src/index.js --mode=order",
    "auth": "node src/index.js --mode=auth --action=check",
    "auth:derive": "node src/index.js --mode=auth --action=derive",
    "auth:create": "node src/index.js --mode=auth --action=create",
    "auth:approve": "node src/index.js --mode=auth --action=approve",
    "volatility": "node src/index.js --mode=volatility",
    "capture": "node src/index.js --mode=capture",
    "stats": "node src/index.js --mode=stats",
    "stats:backtest": "node src/index.js --mode=stats --backtest",
    "resolve": "node src/index.js --mode=resolve",
    "resolve:watch": "node src/index.js --mode=resolve --watch=60",
    "resolve:manual": "node src/index.js --mode=resolve:manual",
    "order:dummy": "node src/index.js --mode=order --strategy=dummy",
    "order:up": "node src/index.js --mode=order --strategy=up-only",
    "order:down": "node src/index.js --mode=order --strategy=down-only",
    "stats:strategies": "node src/index.js --mode=stats --strategies",
    "sim": "node src/index.js --mode=sim",
    "sim:dummy": "node src/index.js --mode=sim --strategy=dummy",
    "sim:up": "node src/index.js --mode=sim --strategy=up-only",
    "sim:down": "node src/index.js --mode=sim --strategy=down-only",
    "sim:momentum": "node src/index.js --mode=sim --strategy=momentum",
    "sim:contrarian": "node src/index.js --mode=sim --strategy=contrarian",
    "order:momentum": "node src/index.js --mode=order --strategy=momentum",
    "sim:value": "node src/index.js --mode=sim --strategy=value",
    "order:value": "node src/index.js --mode=order --strategy=value",
    "redeem": "node src/index.js --mode=redeem",
    "redeem:watch": "node src/index.js --mode=redeem --watch=300",
    "stats:adverse": "node src/index.js --mode=stats --adverse"
  },
  "dependencies": {
    "@polymarket/clob-client": "^4.0.0",
    "ethers": "^5.7.2",
    "dotenv": "^16.3.1",
    "axios": "^1.6.0",
    "chalk": "^4.1.2",
    "ws": "^8.16.0",
    "better-sqlite3": "^9.4.3"
  }
}