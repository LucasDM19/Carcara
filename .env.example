# ============================================================
# CONFIGURAÇÃO DO CARCARÁ
# ============================================================
# NUNCA commite este arquivo com valores reais no git!
# Adicione .env ao seu .gitignore imediatamente.

# --- Carteira Ethereum (Polygon) ---
# Chave privada da carteira que fará as apostas (sem 0x na frente)
PRIVATE_KEY=sua_chave_privada_aqui

# --- Credenciais da API Polymarket (CLOB) ---
# Obtidas em: https://polymarket.com/profile → API Keys
# Após gerar, preencha os 3 campos abaixo:
CLOB_API_KEY=sua_api_key_aqui
CLOB_API_SECRET=seu_api_secret_aqui
CLOB_API_PASSPHRASE=sua_passphrase_aqui

# --- Configuração de Rede ---
# 137 = Polygon Mainnet (produção)
# 80002 = Amoy Testnet (testes — sem dinheiro real)
CHAIN_ID=137

# Host da API CLOB (não altere em produção)
CLOB_HOST=https://clob.polymarket.com

# --- Configuração do Mercado BTC 5min ---
# Parâmetros de execução de ordens
ORDER_WAIT_MS=15000   # ms aguardando preenchimento maker antes de cancelar (30000 = 30s testado, 15000 = padrão mais conservador)
ORDER_MARGIN=0.005    # margem abaixo do midpoint para o preço maker (padrão: 0.5 centavo)

# Proxy wallet da Polymarket (endereço que aparece no seu perfil do site)
# Diferente da sua EOA — é o endereço 0x544eB... mostrado em polymarket.com/profile
PROXY_WALLET=seu_proxy_wallet_aqui

# Condition ID do mercado BTC 5min (muda a cada ciclo)
# Você pode buscá-lo via: npm run market (modo MVP)
# Exemplo abaixo é ilustrativo — sempre atualize!
BTC_MARKET_CONDITION_ID=

# --- Parâmetros de Ordem (Fase 2) ---
# Valor máximo por aposta em USDC (proteção contra bugs)
MAX_BET_SIZE_USDC=5

# Slippage máximo tolerado (0.01 = 1%)
MAX_SLIPPAGE=0.01
